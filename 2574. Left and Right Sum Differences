class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        vector<int> ans1;
        vector<int> ans2(nums.size());
        vector<int> diff;
        int leftSum=0;
        int rightSum=0;
        int answer=0;
        for(int i=0; i<nums.size(); i++){
            ans1.push_back(leftSum);
            leftSum+=nums[i];
        }
        for(int i=nums.size()-1; i>=0; i--){
            ans2[i] = rightSum;
            rightSum+=nums[i];
        }
        for(int i=0; i<nums.size(); i++){
            answer=abs(ans1[i]-ans2[i]);
            diff.push_back(answer);
        }
        return diff;
    }
};
