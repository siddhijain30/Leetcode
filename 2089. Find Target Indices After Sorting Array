class Solution {
public:
    vector<int> targetIndices(vector<int>& nums, int target) {
        vector<int> ans;
        int s=0;
        int e=nums.size()-1;
        sort(nums.begin(), nums.end());
        for(int i=0; i<=e; i++){
            if(nums[i]==target){
                ans.push_back(i);
            }
        }
        return ans;
    }
};
