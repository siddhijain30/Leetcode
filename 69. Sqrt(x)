class Solution {
public:
    int mySqrt(int x) {
        int s = 0;
        int e = x;
        // Use long long for mid to prevent overflow in calculations
        long long mid = s + (e - s) / 2;
        int ans = 0;

        while (s <= e) {
            //where the overflow was happening
            long long square = mid * mid;

            if (square == x) {
                return mid;
            }
            else if (square < x) {
                ans = mid;
                s = mid + 1;
            }
            else {
                e = mid - 1;
            }
            mid = s + (e - s) / 2;
        }
        return ans;
    }
};
