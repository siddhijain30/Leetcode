class Solution {
public:
    bool isPossible(vector<int>& nums, int k, int mid){
        int arrCount=1;
        int pageSum=0;
        for(int i=0; i<nums.size();i++){
            if(pageSum + nums[i] <= mid){
                pageSum += nums[i];
            }
            else{
                arrCount++;
                if(arrCount > k || nums[i] > mid){
                    return false;
                }
                pageSum = nums[i];
            }
        }return true;
    }
    int splitArray(vector<int>& nums, int k) {
        int start=0;
        int sum=0;
        int ans=-1;
        for(int i=0; i<nums.size(); i++){
            sum += nums[i];
        }
        int end=sum;
        int mid=start+(end-start)/2;
        while(start<=end){
            if(isPossible(nums, k, mid)){
                ans=mid;
                end=mid-1;
            }
            else{
                start=mid+1;
            }
            mid=start+(end-start)/2;
        }
        return ans;
    }
};
